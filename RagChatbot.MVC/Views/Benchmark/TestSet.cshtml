@model IEnumerable<RagChatbot.BLL.Services.Interfaces.QuestionGroundTruth>
@{
    ViewData["Title"] = "Ground Truth Test Set (50 câu)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary"><i class="bi bi-file-earmark-spreadsheet-fill me-2"></i>Tập Dữ Liệu Kiểm Thử (Ground Truth)</h2>
            <p class="text-secondary mb-0">Danh sách 50 câu hỏi kèm câu trả lời chuẩn chỉnh và ngữ cảnh chính xác để so sánh hệ thống RAG.</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary rounded-3">
            <i class="bi bi-arrow-left-short me-1"></i> Quay về Dashboard
        </a>
    </div>

    <!-- Info Alert -->
    <div class="alert alert-info rounded-3 mb-4 border-0 shadow-sm" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>
        <strong>Ground Truth:</strong> Là dữ liệu do chuyên gia chuẩn bị sẵn. Chúng tôi dùng nó để so khớp câu trả lời thực tế từ chatbot nhằm chấm điểm các hệ số RAGAS (Độ chính xác, Độ chân thực, Độ liên quan và Độ thu hồi thông tin).
    </div>

    <!-- Search input -->
    <div class="mb-4">
        <input type="text" id="testSetSearch" class="form-control rounded-3 py-2 px-3 border-light shadow-sm" placeholder="Tìm kiếm nhanh trong tập test..." />
    </div>

    <!-- Test Set Table -->
    <div class="card card-custom border-0 shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="testSetTable">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 60px;" class="text-center">STT</th>
                        <th style="width: 250px;">Câu Hỏi (Query)</th>
                        <th>Ngữ Cảnh Gốc (Ground Truth Context)</th>
                        <th>Câu Trả Lời Đúng (Ground Truth Answer)</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr class="test-row">
                            <td class="text-center fw-bold text-secondary">@index</td>
                            <td class="fw-semibold text-dark">@item.Question</td>
                            <td class="text-secondary small">@item.GroundTruthContext</td>
                            <td class="text-indigo small" style="color: #4f46e5;">@item.GroundTruthAnswer</td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Live Search in test table
            $("#testSetSearch").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#testSetTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}
