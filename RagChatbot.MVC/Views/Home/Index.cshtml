@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 text-center shadow-sm">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold text-primary">Hệ Thống RAG Chatbot</h1>
            <p class="col-md-8 fs-4 mx-auto text-muted mt-3">
                Chào mừng bạn đến với ứng dụng quản lý môn học, tài liệu và hỗ trợ giải đáp tự động bằng AI.
            </p>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                <a asp-controller="Subject" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3 shadow">
                    <i class="bi bi-book"></i> Vào Quản lý Môn học
                </a>
            </div>
        </div>
    </div>
</div>