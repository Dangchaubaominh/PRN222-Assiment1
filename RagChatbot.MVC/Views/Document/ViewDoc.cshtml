@model RagChatbot.BLL.DTOs.DocumentDto
@{
    ViewData["Title"] = Model.FileName;
    var ext = System.IO.Path.GetExtension(Model.FileName).ToLower();
}

<div class="breadcrumb-app">
    <a asp-controller="Subject" asp-action="Index"><i class="bi bi-book me-1"></i>Môn học</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <a asp-action="Index" asp-route-subjectId="@Model.SubjectId">Tài liệu</a>
    <span class="sep"><i class="bi bi-chevron-right" style="font-size:10px"></i></span>
    <span class="current">@Model.FileName</span>
</div>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap" class="fade-in-up">
    <div style="display:flex;align-items:center;gap:10px">
        <div class="file-icon @(ext == ".pdf" ? "pdf" : ext == ".txt" ? "txt" : ext == ".docx" ? "docx" : "other")" style="width:40px;height:40px;font-size:20px">
            <i class="bi @(ext == ".pdf" ? "bi-file-earmark-pdf" : ext == ".txt" ? "bi-file-earmark-text" : "bi-file-earmark")"></i>
        </div>
        <div>
            <div style="font-size:16px;font-weight:700;color:var(--text-1)">@Model.FileName</div>
            <div style="font-size:12px;color:var(--text-3)">Tải lên lúc @Model.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-action="Index" asp-route-subjectId="@Model.SubjectId" class="btn-app btn-ghost btn-sm-app">
            <i class="bi bi-arrow-left"></i> Danh sách
        </a>
        <a asp-action="Download" asp-route-id="@Model.Id" class="btn-app btn-primary-app btn-sm-app">
            <i class="bi bi-download"></i> Tải về
        </a>
    </div>
</div>

<div class="card fade-in-up" style="overflow:hidden;height:calc(100vh - var(--topbar-height) - 160px)">
    @if (ext == ".pdf")
    {
        <iframe src="@Model.FilePath" style="width:100%;height:100%;border:none;display:block"></iframe>
    }
    else if (ext == ".txt")
    {
        <div style="height:100%;overflow-y:auto;background:#1E1E2E;padding:24px">
            <pre style="margin:0;white-space:pre-wrap;font-family:'Consolas','Courier New',monospace;font-size:14px;line-height:1.7;color:#CDD6F4">@ViewBag.FileContent</pre>
        </div>
    }
    else if (ext == ".jpg" || ext == ".png" || ext == ".jpeg" || ext == ".gif")
    {
        <div style="height:100%;display:flex;align-items:center;justify-content:center;background:#0F172A">
            <img src="@Model.FilePath" style="max-width:100%;max-height:100%;object-fit:contain" alt="@Model.FileName" />
        </div>
    }
    else
    {
        <div style="height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:40px;text-align:center">
            <i class="bi bi-file-earmark-x" style="font-size:64px;color:var(--text-3)"></i>
            <div>
                <div style="font-size:16px;font-weight:600;color:var(--text-2)">Trình duyệt không hỗ trợ xem định dạng này</div>
                <div style="font-size:13px;color:var(--text-3);margin-top:6px">Vui lòng tải file về để xem nội dung</div>
            </div>
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn-app btn-success-app">
                <i class="bi bi-download"></i> Tải file về máy
            </a>
        </div>
    }
</div>
