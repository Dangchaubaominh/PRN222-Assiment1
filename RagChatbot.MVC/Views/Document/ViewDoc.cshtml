@model RagChatbot.DAL.Entities.Document
@{
    ViewData["Title"] = "Xem Tài liệu: " + Model.FileName;
    // Lấy đuôi file (ví dụ: .pdf, .docx) để hệ thống biết cách hiển thị
    var fileExtension = System.IO.Path.GetExtension(Model.FileName).ToLower();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-file-earmark-text text-primary"></i> @Model.FileName</h4>
        <div>
            <a asp-action="Index" asp-route-subjectId="@Model.SubjectId" class="btn btn-secondary btn-sm">Quay lại danh sách</a>
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                <i class="bi bi-download"></i> Tải về máy
            </a>
        </div>
    </div>
    <hr />

    <div class="card shadow-sm border-0">
        <div class="card-body p-0" style="height: 75vh; background-color: #f8f9fa; border-radius: 8px; overflow: hidden;">

            @if (fileExtension == ".pdf")
            {
                <iframe src="@Model.FilePath" style="width: 100%; height: 100%; border: none;"></iframe>
            }
            else if (fileExtension == ".txt")
            {
                <div class="p-4" style="height: 100%; overflow-y: auto; background-color: #282c34; color: #abb2bf;">
                    <pre style="margin: 0; white-space: pre-wrap; font-family: 'Consolas', 'Courier New', monospace; font-size: 15px; line-height: 1.5;">@ViewBag.FileContent</pre>
                </div>
            }
            else if (fileExtension == ".jpg" || fileExtension == ".png" || fileExtension == ".jpeg")
            {
                <div class="d-flex justify-content-center align-items-center h-100 bg-dark">
                    <img src="@Model.FilePath" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="@Model.FileName" />
                </div>
            }
            else
            {
                <div class="d-flex flex-column justify-content-center align-items-center h-100 p-5 text-center bg-white">
                    <h1 class="display-1 text-primary"><i class="bi bi-file-earmark-x"></i></h1>
                    <h4 class="mt-3">Trình duyệt không hỗ trợ xem trực tiếp định dạng này.</h4>
                    <p class="text-muted">Để xem nội dung hoàn chỉnh không bị lỗi font, vui lòng tải file về máy.</p>
                    <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success mt-2">
                        <i class="bi bi-download"></i> Tải file về máy ngay
                    </a>
                </div>
            }

        </div>
    </div>
</div>